# Proyecto
PROJECT_NAME="Digital Hospital - Auth Service"
VERSION="1.0.0"
ENVIRONMENT="development"
ROOT_PATH="/api/auth"
CORS_ORIGINS='["*"]'

# PostgreSQL
# Example: postgresql+asyncpg://<user>:<password>@<host>:5432/<database>
POSTGRES_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/<database>

# Seguridad / JWT
JWT_SECRET_KEY="<your-secret-key>"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# URLs de Microservicios
# SERVICE_<SERVICE_NAME>_URL=<protocolo>://<host>:<puerto>
SERVICE_CORE_URL=http://localhost:8083
SERVICE_IAM_URL=http://localhost:8082
SERVICE_LOGGER_URL=http://localhost:8092